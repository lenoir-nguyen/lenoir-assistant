# OpenAI Configuration
OPENAI_API_KEY=sk-...

# General Settings
DEBUG=false
FRONTEND_URL=http://localhost:3000
OPENAI_TTS_VOICE=nova

# Authentication (v4+)
# Owner PIN verification using SHA-256 hashing
# To generate hash: python -c "import hashlib; print(hashlib.sha256('YOUR_PIN'.encode()).hexdigest())"
# Example: for PIN "9999", hash is "888df25ae35772424a560c7152a1de794440e0ea5cfee62828333a456a506e05"
OWNER_API_KEY_HASH=

AUTH_TOKEN_TTL=86400

# Cache (v1+)
REDIS_URL=redis://localhost:6379

# Database (v4+)
DATABASE_URL=postgresql://user:password@localhost/lenoir_chatbot
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# Fact Caching (v4.1+)
# Short-term memory for user facts (e.g., "My birthday is May 15")
FACT_CACHE_TTL_OWNER=86400
FACT_CACHE_TTL_GUEST=3600
FACT_CACHE_MAX_ITEMS=50
FACT_EXTRACTION_ENABLED=true

# RAG Configuration (v5+)
# Retrieval-Augmented Generation system with semantic search
RAG_ENABLED=true

# File Storage: 'local' for development, 's3' for production
STORAGE_TYPE=local
DOCUMENT_UPLOAD_DIR=./uploads
MAX_DOCUMENT_SIZE_MB=10

# AWS S3 Configuration (only needed if STORAGE_TYPE=s3)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=your-bucket-name
# AWS_S3_REGION=us-east-1

# Document Chunking Configuration
CHUNK_SIZE=1024
CHUNK_OVERLAP=100
MAX_CHUNKS_PER_QUERY=10
