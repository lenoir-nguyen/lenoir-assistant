# Database
DATABASE_URL=postgresql://user:password@localhost:5432/lenoir_chatbot

# OpenAI API
OPENAI_API_KEY=sk-...

# Identity & Auth
# Generate a PIN hash using: python -c "from services.identity import hash_pin; print(hash_pin('your-pin-here'))"
OWNER_PIN_HASH=$2b$12$...

# Optional: LangChain Tracing
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false

# Server
DEBUG=false
FRONTEND_URL=http://localhost:3000
